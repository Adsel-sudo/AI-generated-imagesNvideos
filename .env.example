REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite:///data/db/app.db

# Google GenAI configuration
# Either GOOGLE_GENAI_API_KEY or GOOGLE_API_KEY can be used.
GOOGLE_GENAI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_IMAGE_BACKEND=google_genai
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image-preview
GOOGLE_VIDEO_MODEL=veo-3.1-fast-generate-001
# Video capability is paused in current release; keep this for internal compatibility only.
PROMPT_OPTIMIZER_MODEL=gemini-3-flash-preview

# Cleanup policy (safer defaults for server deployments)
CLEANUP_UPLOADS_RETENTION_DAYS=14
CLEANUP_OUTPUTS_RETENTION_DAYS=30
CLEANUP_ZIPS_RETENTION_DAYS=3
CLEANUP_LOGS_RETENTION_DAYS=14
CLEANUP_FAILED_CANCELLED_RETENTION_DAYS=7
CLEANUP_SUCCESS_RETENTION_DAYS=30
