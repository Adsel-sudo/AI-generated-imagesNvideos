REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite:///data/db/app.db

# Nginx Basic Auth credentials
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=admin123

# Google GenAI configuration
# Either GOOGLE_GENAI_API_KEY or GOOGLE_API_KEY can be used.
GOOGLE_GENAI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_IMAGE_BACKEND=google_genai
GOOGLE_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
GOOGLE_VIDEO_MODEL=veo-2.0-generate
PROMPT_OPTIMIZER_MODEL=gemini-2.0-flash
